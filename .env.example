# Path to OpenClaw data directory (default: ~/.openclaw)
# OPENCLAW_DIR=~/.openclaw

# OpenClaw gateway port override (default: read from openclaw.json, fallback 18789)
# GATEWAY_PORT=18789

# Client-side gateway port (used by browser health checks, default: 18789)
# NEXT_PUBLIC_GATEWAY_PORT=18789

# Client-side gateway URL override (default: http://localhost:18789)
# Set this when accessing The Guild from a different machine
# NEXT_PUBLIC_GATEWAY_URL=http://192.168.1.100:18789

# OpenClaw gateway host for WebSocket connections (default: localhost)
# OPENCLAW_GATEWAY_HOST=localhost
